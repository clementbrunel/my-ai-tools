# ──────────────────────────────────────────────
# BASE DE DONNÉES
# ──────────────────────────────────────────────
DB_USER=pronocore
DB_PASS=pronocore

# ──────────────────────────────────────────────
# SÉCURITÉ
# ──────────────────────────────────────────────
# Clé de signature JWT — changer impérativement en production (min. 44 caractères)
JWT_SECRET=worldcup2026secretkey1234567890123456789012

# ──────────────────────────────────────────────
# EMAIL (Resend.com)
# ──────────────────────────────────────────────
# Créer une clé sur https://resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here

# ──────────────────────────────────────────────
# FRONTEND / CORS
# ──────────────────────────────────────────────
# URL du frontend — utilisée pour CORS et les liens dans les emails
FRONTEND_URL=http://localhost:5173

# Origine CORS supplémentaire optionnelle (ex: accès réseau local depuis une TV ou NAS)
# CORS_EXTRA_ORIGIN=http://192.168.x.x:3000

# ──────────────────────────────────────────────
# PRODUCTION UNIQUEMENT
# ──────────────────────────────────────────────
# Adresse du registry Docker privé (utilisée par build-and-push.sh et docker-compose.prod.yml)
# REGISTRY=myregistry:5000

# ──────────────────────────────────────────────
# MAINTENANCE
# ──────────────────────────────────────────────
# Répare les checksums Flyway au démarrage (migration éditée après apply).
# Activer une seule fois, redémarrer le backend, puis retirer.
# APP_FLYWAY_REPAIR=true
