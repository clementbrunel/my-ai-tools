{
  "name": "mistral-chat",
  "version": "0.1.0",
  "description": "Interactive CLI REPL to chat with an enterprise Mistral instance via browser session cookies",
  "type": "module",
  "bin": {
    "mistral-chat": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --env-file .env --experimental-sqlite dist/index.js",
    "dev": "tsc && node --env-file .env --experimental-sqlite dist/index.js"
  },
  "keywords": ["mistral", "ai", "chat", "cli", "repl"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^22.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "@inquirer/prompts": "^7.0.0"
  }
}
